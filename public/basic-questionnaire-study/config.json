{
    "$schema": "https://raw.githubusercontent.com/revisit-studies/study/main/src/parser/StudyConfigSchema.json",
    "studyMetadata": {
        "title": "Basic Questionnaire Study",
        "version": "pilot",
        "authors": [
            "The reVISit Team",
            "You :)"
        ],
        "date": "2026-02-23",
        "description": "A simple questionnaire study",
        "organizations": [
            "University of Utah",
            "WPI"
        ]
    },
    "uiConfig": {
        "contactEmail": "your@email.com",
        "helpTextPath": "basic-questionnaire-study/assets/help.md",
        "logoPath": "revisitAssets/revisitLogoSquare.svg",
        "withProgressBar": true,
        "autoDownloadStudy": false,
        "withSidebar": true
    },
    "components": {
        "introduction": {
            "type": "markdown",
            "path": "basic-questionnaire-study/assets/introduction.md",
            "response": []
        },
        "consent": {
            "type": "markdown",
            "path": "tutorial/assets/consent.md",
            "nextButtonText": "I agree",
            "response": []
        },
        "vegaPath": {
            "type": "vega",
            "path": "basic-questionnaire-study/assets/simpleChart.json",
            "response": [
            {
                "id": "simple-vega",
                "type": "radio",
                "prompt": "What is the value of bar A?",
                "options": ["10", "28", "50"]
            }
            ]            
        },
        "vegaPuzzle1": {
            "type": "vega",
            "path": "basic-questionnaire-study/assets/world-choropleth.json",
            "response": [
            {
                "id": "puzzle-1",
                "type": "radio",
                "prompt": "Is the life expectancy of Mexico higher than the life expectancy of Brazil?",
                "options": ["True", "False", "I don't know"]
            }
            ]         
        },
        "vegaPuzzle2": {
            "type": "vega",
            "path": "basic-questionnaire-study/assets/animalWelfareExplorer.json",
            "response": [
            {
                "id": "puzzle-2",
                "type": "radio",
                "prompt": "What was the ratio of goats slaughtered in Pakistan to those slaughtered in China in 2005?",
                "options": ["1 to 2", "1 to 4", "1 to 6", "1 to 8", "I don't know"]
            }
            ]         
        },
        "tuberculosisPuzzle": {
            "type": "website",
            "path": "basic-questionnaire-study/assets/tuberculosisExplorer.html",
            "response": [
            {
                "id": "puzzle-3",
                "type": "radio",
                "prompt": "How did tuberculosis cases evolve in the Philippines from 2010 to 2012?",
                "options": [
                    "The cases decreased each year",
                    "The cases decreased once and then increased",
                    "The cases increased each year",
                    "The cases increased once and then decreased",
                    "I don't know"
                ]
            }
            ]
        },
        "marineProtectedAreasPuzzle": {
            "type": "website",
            "path": "basic-questionnaire-study/assets/marineProtectedAreasExplorer.html",
            "response": [
            {
                "id": "puzzle-4",
                "type": "radio",
                "prompt": "Which of these countries protects the highest percentage of its national waters?",
                "options": [
                    "Greenland",
                    "Brazil",
                    "Singapore",
                    "Jordan",
                    "I don't know"
                ]
            }
            ]
        },
        "movieRatingsPuzzle": {
            "type": "vega",
            "path": "basic-questionnaire-study/assets/movieRatingsExplorer.json",
            "response": [
            {
                "id": "puzzle-5",
                "type": "radio",
                "prompt": "How do the movie ratings and the movie year relate?",
                "options": [
                    "Old movies have high ratings",
                    "New movies have high ratings",
                    "Old movies have low Rotten Tomatoes ratings",
                    "There is no relation between year and moving ratings",
                    "I don't know"
                ]
            }
            ]
        },
        "gapminderPuzzle": {
            "type": "vega",
            "path": "basic-questionnaire-study/assets/gapminderExplorer.json",
            "response": [
            {
                "id": "puzzle-6",
                "type": "radio",
                "prompt": "How does the orange cluster change over time?",
                "options": [
                    "Its life expectancy increases",
                    "Its life expectancy decreases",
                    "Its life expectancy remains the same",
                    "Its fertility increases",
                    "I don't know"
                ]
            }
            ]
        },
        "first-question-set": {
            "type": "questionnaire",
            "response": [
                {
                    "id": "q1-name",
                    "prompt": "What is your first name?",
                    "required": true,
                    "location": "aboveStimulus",
                    "type": "longText",
                    "placeholder": "Please enter your first name"
                },
                {
                    "id": "q2-color",
                    "prompt": "What is your favorite color?",
                    "required": true,
                    "location": "aboveStimulus",
                    "type": "dropdown",
                    "placeholder": "Please choose your favorite color",
                    "options": ["Red", "Blue", "My favorite color is not shown here."]
                }
            ]
        },
        "second-question-set": {
            "type": "questionnaire",
            "response": [
                {
                    "id": "q3-satisfaction",
                    "prompt": "Rate your satisfaction with this survey from 1 (not enjoyable) to 5 (very enjoyable).",
                    "required": true,
                    "location": "aboveStimulus",
                    "type": "likert",
                    "leftLabel": "Not Enjoyable",
                    "rightLabel": "Very Enjoyable",
                    "numItems": 5
                }
            ]
        }
    },
    "sequence": {
        "order": "fixed",
        "components": [
            "introduction",
            "consent",
            "vegaPuzzle1",
            "vegaPuzzle2",
            "tuberculosisPuzzle",
            "marineProtectedAreasPuzzle",
            "movieRatingsPuzzle",
            "gapminderPuzzle"
        ]
    }
}